# ── Required ────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# ── Optional ────────────────────────────────────────────────────────────────
PORT=3000
FLASK_URL=http://localhost:5000
NODE_ENV=development
JWT_EXPIRY=8h

# ── Users ────────────────────────────────────────────────────────────────────
# Add users by running:  npm run add-user
# Paste the printed line below. Username is the part after USER_
# Example (do NOT use this hash in production):
# USER_OJASH=$2b$10$examplehashexamplehashexamplehashexamplehash
