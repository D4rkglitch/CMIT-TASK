# CHiPS Production Environment Configuration
# Copy this file to .env and fill in actual values
# WARNING: Never commit .env to version control!

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: API Keys & Credentials
# ═══════════════════════════════════════════════════════════════════════════════

# Sarvam AI API Key (for OCR fallback on low-confidence pages)
# Get from: https://console.sarvam.ai/
SARVAM_API_KEY=sk_your_api_key_here

# (Optional) GROQ API Key (for future LLM integration)
# GROQ_API_KEY=gsk_your_groq_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# Stage 1: Image Preprocessing
# ═══════════════════════════════════════════════════════════════════════════════

# PDF to image conversion DPI (higher = better quality, slower processing)
STAGE1_DPI=450

# Denoising configuration
STAGE1_DENOISE_ENABLED=true
STAGE1_DENOISE_STRENGTH=0.5

# Deskewing configuration
STAGE1_DESKEW_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# Stage 2: OCR & Structure Extraction
# ═══════════════════════════════════════════════════════════════════════════════

# Docling OCR engine language list
STAGE2_LANGUAGES=en,hi

# Confidence threshold for Docling OCR (0.0-1.0)
# Pages below this threshold will use Sarvam AI OCR as fallback
STAGE2_CONFIDENCE_THRESHOLD=0.7

# Sarvam fallback OCR threshold
STAGE2_SARVAM_THRESHOLD=0.5

# ═══════════════════════════════════════════════════════════════════════════════
# Stage 3: Semantic Chunking
# ═══════════════════════════════════════════════════════════════════════════════

# Maximum tokens per chunk
STAGE3_MAX_TOKENS=1024

# Embedding model for chunking
STAGE3_EMBEDDING_MODEL=BAAI/bge-m3

# ═══════════════════════════════════════════════════════════════════════════════
# Stage 4: Embeddings & Vector Database
# ═══════════════════════════════════════════════════════════════════════════════

# Qdrant vector database collection name
CHIPPY_QDRANT_COLLECTION=db3

# Qdrant local database path (relative to project root)
CHIPPY_QDRANT_LOCAL_PATH=04_embeddings_and_kg/db/qdrant_local

# Chunk directory (where Stage 3 output is stored)
CHIPPY_CHUNK_DIR=03_chunking/output

# Embedding batch size (higher = faster, but uses more memory)
STAGE4_BATCH_SIZE=8

# Vector embedding max length
STAGE4_MAX_LENGTH=1024

# Hybrid retrieval alpha (0.0 = sparse only, 1.0 = dense only, 0.6 = 60% dense)
STAGE4_HYBRID_ALPHA=0.6

# ═══════════════════════════════════════════════════════════════════════════════
# Stage 5: Web UI & RAG
# ═══════════════════════════════════════════════════════════════════════════════

# Flask server configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=production
FLASK_DEBUG=false

# RAG retrieval parameters
RAG_RERANK_MIN_K=3
RAG_RERANK_MAX_K=6
RAG_RERANK_THRESHOLD=0.65

# ═══════════════════════════════════════════════════════════════════════════════
# Logging & Monitoring
# ═══════════════════════════════════════════════════════════════════════════════

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log output directory (relative to project root)
LOG_DIR=logs

# Enable file logging
LOG_FILE_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# Development & Debug
# ═══════════════════════════════════════════════════════════════════════════════

# Enable performance profiling
ENABLE_PROFILING=false

# Enable debug mode for development (DO NOT USE IN PRODUCTION)
DEBUG_MODE=false
